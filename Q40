#include <stdio.h>

int main() {
    int rows;
    printf("Enter number of rows: ");
    scanf("%d", &rows);

    for (int i = 1; i <= rows; i++) {
        // Print leading spaces
        for (int space = 1; space <= rows - i; space++) {
            printf("  ");
        }
        
        char ch = 'A';
        // Print increasing character chain
        for (int j = 1; j <= i; j++) {
            printf("%c ", ch);
            ch++;
        }
        
        ch -= 2; // Step back to previous character for downward run
        // Print decreasing character chain
        for (int j = i - 1; j >= 1; j--) {
            printf("%c ", ch);
            ch--;
        }
        printf("\n");
    }
    return 0;
}
