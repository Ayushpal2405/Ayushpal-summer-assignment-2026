#include <stdio.h>

int main() {
    int n, t1 = 0, t2 = 1, nextTerm;

    printf("Enter the position (n) of the Fibonacci term: ");
    scanf("%d", &n);

    if (n <= 0) {
        printf("Please enter a positive integer.\n");
        return 0;
    }

    if (n == 1) {
        printf("The 1st Fibonacci term is: %d\n", t1);
        return 0;
    }

    for (int i = 3; i <= n; i++) {
        nextTerm = t1 + t2;
        t1 = t2;
        t2 = nextTerm;
    }

    printf("The %d-th Fibonacci term is: %d\n", n, t2);
    return 0;
}
