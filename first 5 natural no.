#include <stdio.h>

int main() {
    int n, sum = 0;

    // Asking for user input
    printf("Enter a positive integer: ");
    scanf("%d", &n);

    // Loop from 1 to n and accumulate the total
    for (int i = 1; i <= n; i++) {
        sum += i;
    }

    printf("The sum of the first %d natural numbers is: %d\n", n, sum);

    return 0;
}
