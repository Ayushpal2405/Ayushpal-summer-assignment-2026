#include <stdio.h>

int main() {
    long long binary, temp;
    int decimal = 0, base = 1, remainder;

    printf("Enter a binary number: ");
    scanf("%lld", &binary);

    temp = binary;
    while (temp > 0) {
        remainder = temp % 10;
        decimal = decimal + remainder * base;
        temp = temp / 10;
        base = base * 2;
    }

    printf("Decimal equivalent of %lld is: %d\n", binary, decimal);
    return 0;
}
