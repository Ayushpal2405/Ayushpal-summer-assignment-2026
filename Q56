#include <stdio.h>

int main() {
    int n;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    int arr[n];
    // Array to track if an element's duplicate has already been printed
    int visited[n]; 

    printf("Enter %d elements:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        visited[i] = 0; // Initialize tracking array
    }

    printf("Duplicate elements in the given array: \n");
    int hasDuplicates = 0;

    // Nested loops to spot duplicates
    for (int i = 0; i < n; i++) {
        if (visited[i] == 1) {
            continue; // Skip if we've already handled this duplicate pair
        }

        int count = 1;
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
                visited[j] = 1; // Mark as visited so it isn't evaluated again
            }
        }

        // If count > 1, a duplicate exists
        if (count > 1) {
            printf("%d (appears %d times)\n", arr[i], count);
            hasDuplicates = 1;
        }
    }

    if (!hasDuplicates) {
        printf("No duplicate elements found.\n");
    }

    return 0;
}
