#include <stdio.h>

int recursiveSumOfDigits(int n) {
    if (n == 0) 
        return 0;
    return (n % 10) + recursiveSumOfDigits(n / 10);
}

int main() {
    int num;
    printf("Enter an integer: ");
    scanf("%d", &num);

    int temp = num < 0 ? -num : num; // Handle negative numbers

    printf("Sum of digits of %d is: %d\n", num, recursiveSumOfDigits(temp));
    return 0;
}
