#include <stdio.h>

int main() {
    int size;
    printf("Enter side length of square: ");
    scanf("%d", &size);

    for (int i = 1; i <= size; i++) {
        for (int j = 1; j <= size; j++) {
            // Check if boundary position
            if (i == 1 || i == size || j == 1 || j == size) {
                printf("* ");
            } else {
                printf("  "); // Two spaces for alignment
            }
        }
        printf("\n");
    }
    return 0;
}
