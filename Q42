#include <stdio.h>

// Function definition to find the maximum of two numbers
int findMaximum(int a, int b) {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

int main() {
    int num1, num2, max;

    printf("Enter two integers: ");
    scanf("%d %d", &num1, &num2);

    // Calling the function
    max = findMaximum(num1, num2);

    printf("The maximum value between %d and %d is: %d\n", num1, num2, max);
    return 0;
}
