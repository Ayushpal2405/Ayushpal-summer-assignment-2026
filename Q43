#include <stdio.h>

// Function definition to check prime status
// Returns 1 if prime, 0 if not prime
int checkPrime(int n) {
    if (n <= 1) {
        return 0; // 0 and 1 are not prime numbers
    }
    
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            return 0; // Found a factor, so it's not prime
        }
    }
    return 1; // No factors found, it is prime
}

int main() {
    int num;

    printf("Enter a positive integer: ");
    scanf("%d", &num);

    // Calling the function inside a conditional statement
    if (checkPrime(num)) {
        printf("%d is a prime number.\n", num);
    } else {
        printf("%d is not a prime number.\n", num);
    }

    return 0;
}
