#include <stdio.h>

// Function to find the nth Fibonacci term
int getNthFibonacci(int n) {
    if (n <= 0) return 0;
    if (n == 1) return 1;
    
    int a = 0, b = 1, nextTerm;
    for (int i = 2; i <= n; i++) {
        nextTerm = a + b;
        a = b;
        b = nextTerm;
    }
    return b;
}

int main() {
    int n;
    printf("Enter the value of n: ");
    scanf("%d", &n);
    
    printf("The %d-th Fibonacci term is: %d\n", n, getNthFibonacci(n));
    return 0;
}
