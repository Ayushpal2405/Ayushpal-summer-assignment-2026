#include <stdio.h>

int main() {
    double base, result = 1.0;
    int exponent;

    printf("Enter base: ");
    scanf("%lf", &base);
    printf("Enter exponent (integer): ");
    scanf("%d", &exponent);

    int exp = exponent;
    if (exp < 0) exp = -exp; // Handle negative exponents

    for (int i = 1; i <= exp; i++) {
        result *= base;
    }

    if (exponent < 0) {
        result = 1.0 / result;
    }

    printf("%.2lf^%d = %.6lf\n", base, exponent, result);
    return 0;
}
